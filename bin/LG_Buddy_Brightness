#!/bin/bash

if command -v lg-buddy >/dev/null 2>&1; then
    exec lg-buddy brightness "$@"
fi

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -r "$SCRIPT_DIR/LG_Buddy_Common" ]; then
    . "$SCRIPT_DIR/LG_Buddy_Common"
elif [ -r "/usr/lib/lg-buddy/common.sh" ]; then
    . "/usr/lib/lg-buddy/common.sh"
else
    echo "LG Buddy common helper not found."
    exit 1
fi

lg_buddy_load_config || exit 1

BSCPYLGTV="/usr/bin/LG_Buddy_PIP/bin/bscpylgtvcommand"

# Check if TV is reachable before showing the slider
if ! ping -c 1 -W 2 "$tv_ip" &>/dev/null; then
    zenity --error --title="LG Buddy" --text="TV is not reachable at $tv_ip."
    exit 1
fi

BRIGHTNESS=$(zenity --scale \
    --title="LG TV Brightness" \
    --text="Set OLED Pixel Brightness:" \
    --min-value=0 --max-value=100 --value=50 --step=5)

if [ $? -ne 0 ]; then
    exit 0
fi

if "$BSCPYLGTV" "$tv_ip" set_settings picture "{\"backlight\": $BRIGHTNESS}"; then
    notify-send "LG TV" "Brightness set to $BRIGHTNESS%"
else
    notify-send "LG TV" "Failed to set brightness"
    exit 1
fi
