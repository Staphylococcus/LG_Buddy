#!/bin/bash

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -r "$SCRIPT_DIR/LG_Buddy_Common" ]; then
    . "$SCRIPT_DIR/LG_Buddy_Common"
elif [ -r "/usr/lib/lg-buddy/common.sh" ]; then
    . "/usr/lib/lg-buddy/common.sh"
else
    echo "LG Buddy common helper not found."
    exit 1
fi

lg_buddy_load_config || exit 1

STATE_DIR="/run/user/$(id -u)/lg_buddy"
STATE_FILE="${STATE_DIR}/screen_off_by_us"
BSCPYLGTV="/usr/bin/LG_Buddy_PIP/bin/bscpylgtvcommand"

expected_app="$(lg_buddy_expected_app "$input")"

log() {
    echo "LG Buddy Screen Off: $*"
}

# Check current TV input
current_input="$(lg_buddy_get_current_input "$BSCPYLGTV" "$tv_ip")"
get_input_rc=$?

if [ $get_input_rc -ne 0 ] || [ -z "$current_input" ]; then
    # get_input failed (TV off, unreachable, or timeout)
    log "Could not query TV input (rc=$get_input_rc). Falling back to power_off."
    mkdir -p "$STATE_DIR"
    if "$BSCPYLGTV" "$tv_ip" power_off 2>&1; then
        touch "$STATE_FILE"
    else
        log "Could not power off the TV (may already be off or unreachable)."
    fi
    exit 0
fi

if [ "$current_input" = "$expected_app" ]; then
    log "TV is on $input. Attempting screen blank for idle..."
    mkdir -p "$STATE_DIR"
    if "$BSCPYLGTV" "$tv_ip" turn_screen_off 2>&1; then
        touch "$STATE_FILE"
        log "Screen blank command succeeded."
    else
        log "Screen blank failed. Falling back to power_off."
        if "$BSCPYLGTV" "$tv_ip" power_off 2>&1; then
            touch "$STATE_FILE"
            log "Fallback power_off succeeded."
        else
            log "Fallback power_off failed."
        fi
    fi
else
    log "TV is on $current_input (not $input). Skipping idle action."
    # Remove stale state file if it exists
    rm -f "$STATE_FILE"
fi
