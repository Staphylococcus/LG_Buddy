#!/bin/bash

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -r "$SCRIPT_DIR/LG_Buddy_Common" ]; then
    . "$SCRIPT_DIR/LG_Buddy_Common"
elif [ -r "/usr/lib/lg-buddy/common.sh" ]; then
    . "/usr/lib/lg-buddy/common.sh"
else
    echo "LG Buddy common helper not found."
    exit 1
fi

screen_backend="$LG_BUDDY_DEFAULT_SCREEN_BACKEND"
screen_idle_timeout="$LG_BUDDY_DEFAULT_IDLE_TIMEOUT"
lg_buddy_load_config >/dev/null 2>&1 || true

SCREEN_BACKEND="${LG_BUDDY_SCREEN_BACKEND:-$screen_backend}"
IDLE_TIMEOUT="${LG_BUDDY_IDLE_TIMEOUT:-$screen_idle_timeout}"

if [ -r "$SCRIPT_DIR/LG_Buddy_Screen_Off" ]; then
    SCREEN_OFF_CMD="$SCRIPT_DIR/LG_Buddy_Screen_Off"
else
    SCREEN_OFF_CMD="/usr/bin/LG_Buddy_Screen_Off"
fi

if [ -r "$SCRIPT_DIR/LG_Buddy_Screen_On" ]; then
    SCREEN_ON_CMD="$SCRIPT_DIR/LG_Buddy_Screen_On"
else
    SCREEN_ON_CMD="/usr/bin/LG_Buddy_Screen_On"
fi
GNOME_DBUS_NAME="org.gnome.ScreenSaver"
GNOME_DBUS_PATH="/org/gnome/ScreenSaver"
GNOME_IDLE_MONITOR_NAME="org.gnome.Mutter.IdleMonitor"
GNOME_IDLE_MONITOR_PATH="/org/gnome/Mutter/IdleMonitor/Core"
GNOME_ACTIVE_THRESHOLD_MS=1000
GNOME_ACTIVE_POLL_INTERVAL=0.25
GNOME_WAIT_TIMEOUT=15
SCREEN_STATE_FILE="/run/user/$(id -u)/lg_buddy/screen_off_by_us"

log() {
    echo "LG Buddy Screen Monitor: $*"
}

have_command() {
    command -v "$1" >/dev/null 2>&1
}

dbus_name_has_owner() {
    gdbus call --session \
        --dest org.freedesktop.DBus \
        --object-path /org/freedesktop/DBus \
        --method org.freedesktop.DBus.NameHasOwner \
        "$1" 2>/dev/null | grep -q "(true,)"
}

wait_for_dbus_name() {
    gdbus wait --session --timeout "$2" "$1" >/dev/null 2>&1
}

get_gnome_idletime() {
    local idletime=""

    idletime="$(gdbus call --session \
        --dest "$GNOME_IDLE_MONITOR_NAME" \
        --object-path "$GNOME_IDLE_MONITOR_PATH" \
        --method org.gnome.Mutter.IdleMonitor.GetIdletime 2>/dev/null |
        sed -n 's/^(uint64 \([0-9][0-9]*\),)$/\1/p')"

    [ -n "$idletime" ] || return 1
    echo "$idletime"
}

stop_gnome_activity_watch() {
    if [ -n "${GNOME_ACTIVITY_WATCH_PID:-}" ] && kill -0 "$GNOME_ACTIVITY_WATCH_PID" 2>/dev/null; then
        kill "$GNOME_ACTIVITY_WATCH_PID" 2>/dev/null || true
        wait "$GNOME_ACTIVITY_WATCH_PID" 2>/dev/null || true
    fi

    GNOME_ACTIVITY_WATCH_PID=""
}

start_gnome_activity_watch() {
    stop_gnome_activity_watch

    if [ "${GNOME_IDLE_MONITOR_AVAILABLE:-0}" -ne 1 ]; then
        return 0
    fi

    (
        local idletime=""

        while [ -f "$SCREEN_STATE_FILE" ]; do
            idletime="$(get_gnome_idletime)" || {
                sleep "$GNOME_ACTIVE_POLL_INTERVAL"
                continue
            }

            if [ "$idletime" -lt "$GNOME_ACTIVE_THRESHOLD_MS" ]; then
                log "Mutter idle monitor detected user activity."
                "$SCREEN_ON_CMD"
                exit 0
            fi

            sleep "$GNOME_ACTIVE_POLL_INTERVAL"
        done
    ) &

    GNOME_ACTIVITY_WATCH_PID=$!
}

detect_backend() {
    case "$SCREEN_BACKEND" in
        auto)
            if have_command gdbus && (dbus_name_has_owner org.gnome.Shell || wait_for_dbus_name org.gnome.Shell 2); then
                echo "gnome"
                return 0
            fi

            if have_command swayidle; then
                echo "swayidle"
                return 0
            fi

            log "No supported screen backend detected. Install swayidle or run under GNOME."
            return 1
            ;;
        gnome)
            if ! have_command gdbus; then
                log "Backend forced to GNOME, but gdbus is not installed."
                return 1
            fi

            echo "gnome"
            return 0
            ;;
        swayidle)
            if ! have_command swayidle; then
                log "Backend forced to swayidle, but swayidle is not installed."
                return 1
            fi

            echo "swayidle"
            return 0
            ;;
        *)
            log "Unsupported backend '$SCREEN_BACKEND'. Use auto, gnome, or swayidle."
            return 1
            ;;
    esac
}

run_gnome_backend() {
    GNOME_IDLE_MONITOR_AVAILABLE=0
    GNOME_ACTIVITY_WATCH_PID=""

    if ! wait_for_dbus_name org.gnome.Shell "$GNOME_WAIT_TIMEOUT"; then
        log "Timed out waiting for GNOME Shell on the session bus."
        return 1
    fi

    if ! gdbus call --session \
        --dest "$GNOME_DBUS_NAME" \
        --object-path "$GNOME_DBUS_PATH" \
        --method org.gnome.ScreenSaver.GetActive >/dev/null 2>&1; then
        log "Could not connect to org.gnome.ScreenSaver."
        return 1
    fi

    if gdbus call --session \
        --dest "$GNOME_IDLE_MONITOR_NAME" \
        --object-path "$GNOME_IDLE_MONITOR_PATH" \
        --method org.gnome.Mutter.IdleMonitor.GetIdletime >/dev/null 2>&1; then
        GNOME_IDLE_MONITOR_AVAILABLE=1
    else
        log "Could not connect to org.gnome.Mutter.IdleMonitor. Early wake detection disabled."
    fi

    log "Using GNOME backend."

    trap 'stop_gnome_activity_watch' EXIT

    gdbus monitor --session --dest "$GNOME_DBUS_NAME" --object-path "$GNOME_DBUS_PATH" |
        while IFS= read -r line; do
            case "$line" in
                *"org.gnome.ScreenSaver.ActiveChanged (true,)"*)
                    log "GNOME reported the screen inactive."
                    "$SCREEN_OFF_CMD"
                    start_gnome_activity_watch
                    ;;
                *"org.gnome.ScreenSaver.WakeUpScreen"*|*"member=WakeUpScreen"*)
                    log "GNOME requested the screen wake."
                    stop_gnome_activity_watch
                    "$SCREEN_ON_CMD"
                    ;;
                *"org.gnome.ScreenSaver.ActiveChanged (false,)"*)
                    log "GNOME reported the screen active."
                    stop_gnome_activity_watch
                    "$SCREEN_ON_CMD"
                    ;;
            esac
        done

    return "${PIPESTATUS[0]}"
}

run_swayidle_backend() {
    log "Using swayidle backend (timeout: ${IDLE_TIMEOUT}s)."

    exec swayidle -w \
        timeout "$IDLE_TIMEOUT" "$SCREEN_OFF_CMD" \
        resume "$SCREEN_ON_CMD"
}

main() {
    local backend

    case "${1:-}" in
        --detect-backend)
            detect_backend
            return $?
            ;;
        --help)
            echo "Usage: $0 [--detect-backend]"
            return 0
            ;;
    esac

    backend="$(detect_backend)" || exit 1

    case "$backend" in
        gnome)
            run_gnome_backend
            ;;
        swayidle)
            run_swayidle_backend
            ;;
    esac
}

main "$@"
