#!/bin/bash

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -r "$SCRIPT_DIR/LG_Buddy_Common" ]; then
    . "$SCRIPT_DIR/LG_Buddy_Common"
elif [ -r "/usr/lib/lg-buddy/common.sh" ]; then
    . "/usr/lib/lg-buddy/common.sh"
else
    echo "LG Buddy common helper not found."
    exit 1
fi

lg_buddy_load_config || exit 1

STATE_DIR="/run/lg_buddy"
STATE_FILE="${STATE_DIR}/screen_off_by_us"

nm-online -q -t 60

mode="${1:-auto}"

if [ "$mode" = "wake" ]; then
    if [ -f "$STATE_FILE" ]; then
        echo "Wake from sleep: LG Buddy turned TV off. Restoring."
        rm -f "$STATE_FILE"
    else
        echo "Wake from sleep: TV was not on our input. Skipping."
        exit 0
    fi
elif [ "$mode" = "boot" ]; then
    echo "Cold boot: Turning TV on and switching to $input."
    rm -f "$STATE_FILE"
else
    if [ -f "$STATE_FILE" ]; then
        echo "Wake from sleep: LG Buddy turned TV off. Restoring."
        rm -f "$STATE_FILE"
    else
        echo "Cold boot: Turning TV on and switching to $input."
    fi
fi

lg_buddy_send_wol "$tv_mac" || true

# Let the TV fully bring up its WebSocket endpoint after WoL.
sleep 6

for i in 1 2 3 4 5 6; do
    if /usr/bin/LG_Buddy_PIP/bin/bscpylgtvcommand "$tv_ip" set_input "$input" 2>&1; then
        echo "TV turned on and set to $input."
        exit 0
    fi
    retry_delay=$(( (i * 2) > 30 ? 30 : (i * 2) ))
    echo "Attempt $i failed, retrying in ${retry_delay}s..."
    lg_buddy_send_wol "$tv_mac" || true
    sleep "$retry_delay"
done

echo "set_input failed after 6 attempts"
