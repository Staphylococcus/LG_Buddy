#!/bin/bash

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -r "$SCRIPT_DIR/LG_Buddy_Common" ]; then
    . "$SCRIPT_DIR/LG_Buddy_Common"
elif [ -r "/usr/lib/lg-buddy/common.sh" ]; then
    . "/usr/lib/lg-buddy/common.sh"
else
    echo "LG Buddy common helper not found."
    exit 1
fi

lg_buddy_load_config || exit 1

STATE_DIR="/run/user/$(id -u)/lg_buddy"
STATE_FILE="${STATE_DIR}/screen_off_by_us"
BSCPYLGTV="/usr/bin/LG_Buddy_PIP/bin/bscpylgtvcommand"

log() {
    echo "LG Buddy Screen On: $*"
}

# Only wake the TV if we were the ones who turned it off
if [ ! -f "$STATE_FILE" ]; then
    log "State file not found. TV was not turned off by LG Buddy. Skipping wake."
    exit 0
fi

# Guard against stale state files from crashes / abnormal session ends
if [ -n "$(find "$STATE_FILE" -mmin +720 2>/dev/null)" ]; then
    log "State file is stale (>12h old). Removing and skipping wake."
    rm -f "$STATE_FILE"
    exit 0
fi

log "Turning TV on (screen wake) using input $input..."

log "Attempting screen unblank..."
turn_screen_on_output="$("$BSCPYLGTV" "$tv_ip" turn_screen_on 2>&1)"
turn_screen_on_rc=$?
if [ $turn_screen_on_rc -eq 0 ]; then
    printf '%s\n' "$turn_screen_on_output"
    log "Screen unblank succeeded. Clearing wake state."
    rm -f "$STATE_FILE"
    exit 0
fi

printf '%s\n' "$turn_screen_on_output"

if printf '%s\n' "$turn_screen_on_output" | grep -q "errorCode': '-102'"; then
    log "TV reported an active screen state. Trying immediate input restore before full wake."
    if "$BSCPYLGTV" "$tv_ip" set_input "$input" 2>&1; then
        log "Immediate input restore succeeded. Clearing wake state."
        rm -f "$STATE_FILE"
        exit 0
    fi
fi

log "Screen unblank failed. Falling back to full wake."

log "Sending initial Wake-on-LAN packet..."
lg_buddy_send_wol "$tv_mac" || true

# Wait for TV to fully wake up and accept WebSocket connections
sleep 6

for i in 1 2 3 4 5 6; do
    log "Wake attempt $i: setting input to $input..."
    if "$BSCPYLGTV" "$tv_ip" set_input "$input" 2>&1; then
        log "Wake attempt $i succeeded. Clearing wake state."
        rm -f "$STATE_FILE"
        exit 0
    fi

    retry_delay=$(( (i * 2) > 30 ? 30 : (i * 2) ))
    log "Wake attempt $i failed. Resending WoL and retrying in ${retry_delay}s..."
    lg_buddy_send_wol "$tv_mac" || true
    sleep "$retry_delay"
done

log "Wake failed after 6 attempts. Leaving state file in place for another resume event."
exit 1
