#!/bin/bash

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
if [ -r "$SCRIPT_DIR/LG_Buddy_Common" ]; then
    . "$SCRIPT_DIR/LG_Buddy_Common"
elif [ -r "/usr/lib/lg-buddy/common.sh" ]; then
    . "/usr/lib/lg-buddy/common.sh"
else
    echo "LG Buddy common helper not found."
    exit 1
fi

lg_buddy_load_config || exit 1

STATE_DIR="/run/lg_buddy"
STATE_FILE="${STATE_DIR}/screen_off_by_us"
BSCPYLGTV="/usr/bin/LG_Buddy_PIP/bin/bscpylgtvcommand"

state_was_set=0
if [ -f "$STATE_FILE" ]; then
    state_was_set=1
fi

mkdir -p "$STATE_DIR"

expected_app="$(lg_buddy_expected_app "$input")"

current_input="$(lg_buddy_get_current_input "$BSCPYLGTV" "$tv_ip")"
get_input_rc=$?

if [ $get_input_rc -ne 0 ]; then
    for retry in 1 2 3; do
        sleep 1
        current_input="$(lg_buddy_get_current_input "$BSCPYLGTV" "$tv_ip")"
        get_input_rc=$?
        [ $get_input_rc -eq 0 ] && break
    done
fi

if [ $get_input_rc -eq 0 ] && [ "$current_input" = "$expected_app" ]; then
    echo "TV is on $input. Turning off for sleep."
    if "$BSCPYLGTV" "$tv_ip" power_off 2>&1; then
        touch "$STATE_FILE"
    else
        echo "power_off failed on known input. State not set."
    fi
elif [ $get_input_rc -ne 0 ]; then
    echo "Could not query TV input. Attempting power_off fallback."
    fallback_ok=0
    for retry in 1 2 3 4; do
        if "$BSCPYLGTV" "$tv_ip" power_off 2>&1; then
            fallback_ok=1
            break
        fi
        sleep 1
    done

    if [ $fallback_ok -eq 1 ]; then
        touch "$STATE_FILE"
    else
        if [ $state_was_set -eq 1 ]; then
            echo "Fallback power_off failed, but state already set by another hook. Keeping state."
        else
            echo "Fallback power_off failed after retries. Leaving state unset."
            rm -f "$STATE_FILE"
        fi
    fi
else
    echo "TV is on $current_input (not $input). Skipping."
    rm -f "$STATE_FILE"
fi

exit 0
